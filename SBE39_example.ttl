@prefix ex:         <https://example.org/resource/> .
@prefix ososa:      <https://w3id.org/ocean-sosa/> .
@prefix sosa:       <http://www.w3.org/ns/sosa/> .
@prefix ssn:        <http://www.w3.org/ns/ssn/> .
@prefix ssn-system: <http://www.w3.org/ns/ssn/systems/> .
@prefix qudt:       <http://qudt.org/schema/qudt/> .
@prefix unit:       <http://qudt.org/vocab/unit/> .
@prefix cf:         <http://vocab.nerc.ac.uk/standard_name/> .
@prefix schema:     <https://schema.org/> .
@prefix xsd:        <http://www.w3.org/2001/XMLSchema#> .

#################################################################
# Modello generale
#################################################################

ex:SeaBirdSBE37
    a ososa:SensorModel ;
    rdfs:label "Sea-Bird SBE37 MicroCAT"@en ;
    schema:manufacturer ex:SeaBirdScientific ;
    schema:model "SBE37" ;
    ssn:hasSubSystem ex:SBE37_TemperatureComponent ;
    ssn:hasSubSystem ex:SBE37_ConductivityComponent ;
    ssn:hasSubSystem ex:SBE37_PressureComponent .

#################################################################
# Componenti nominali del modello
#################################################################

ex:SBE37_TemperatureComponent
    a ososa:SensingComponent ;
    rdfs:label "SBE37 nominal temperature sensing component"@en ;
    ososa:designedToObserve cf:sea_water_temperature ;
    ososa:hasDefaultUnit unit:DEG_C ;
    ososa:hasModelCapability ex:SBE37_TemperatureAccuracy ;
    ososa:hasModelCapability ex:SBE37_TemperatureResolution ;
    ososa:hasModelOperatingRange ex:SBE37_TemperatureOperatingRange .

ex:SBE37_ConductivityComponent
    a ososa:SensingComponent ;
    rdfs:label "SBE37 nominal conductivity sensing component"@en ;
    ososa:designedToObserve cf:sea_water_electrical_conductivity ;
    ososa:hasDefaultUnit unit:S-PER-M ;
    ososa:hasModelCapability ex:SBE37_ConductivityAccuracy ;
    ososa:hasModelCapability ex:SBE37_ConductivityResolution .

ex:SBE37_PressureComponent
    a ososa:SensingComponent ;
    rdfs:label "SBE37 nominal pressure sensing component"@en ;
    ososa:designedToObserve cf:sea_water_pressure ;
    ososa:hasDefaultUnit unit:Decibar ;
    ososa:hasModelCapability ex:SBE37_PressureAccuracy ;
    ososa:hasModelCapability ex:SBE37_PressureResolution .
